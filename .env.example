DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boking?schema=public"
# Optional: enable verbose Prisma SQL logging in local development.
PRISMA_LOG_QUERIES="false"
JWT_SECRET="change-me-to-a-long-random-secret-at-least-16-chars"
ADMIN_LOGIN="admin"
# Escape each "$" as "\$" when storing a bcrypt hash in .env files.
ADMIN_PASSWORD_HASH="\$2b\$10\$replace-with-your-bcrypt-hash"
ADMIN_JWT_SECRET="change-me-to-a-long-random-admin-secret-at-least-16-chars"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CSRF_TRUSTED_ORIGINS=""
RATE_LIMIT_MODE="auto"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
SECURITY_EMAIL_DELIVERY_MODE="log"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SECURITY_EMAIL_FROM=""
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""
YANDEX_GEOCODER_API_KEY=""
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL=""
# Secret for the /api/cron/cleanup-drafts endpoint (generate with: openssl rand -hex 32)
CRON_SECRET=""
LISTING_ANALYTICS_TIME_ZONE="Europe/Moscow"
LISTING_ANALYTICS_AUTO_UPDATE_HOUR="4"
LISTING_ANALYTICS_CRON_BATCH_LIMIT="150"
