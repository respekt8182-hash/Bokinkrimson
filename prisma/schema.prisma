// Core relational schema for auth + owner property wizard (steps 1-7).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum PasswordResetRequestStatus {
  PENDING
  COMPLETED
}

enum PropertyStatus {
  DRAFT              @map("draft")
  PENDING_MODERATION @map("pending_moderation")
  PUBLISHED          @map("published")
  REJECTED           @map("rejected")
}

enum ExcursionStatus {
  DRAFT              @map("draft")
  PENDING_MODERATION @map("pending_moderation")
  PUBLISHED          @map("published")
  NEEDS_FIX          @map("needs_fix")
  REJECTED           @map("rejected")
}

enum AttractionStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  HIDDEN    @map("hidden")
}

enum TransferStatus {
  DRAFT              @map("draft")
  PENDING_MODERATION @map("pending_moderation")
  PUBLISHED          @map("published")
  REJECTED           @map("rejected")
}

enum ExcursionLocationKind {
  CITY     @map("city")
  TOWN     @map("town")
  VILLAGE  @map("village")
  LANDMARK @map("landmark")
  BEACH    @map("beach")
  TRAIL    @map("trail")
  OTHER    @map("other")
}

enum ExcursionFormat {
  GROUP      @map("group")
  PRIVATE    @map("private")
  INDIVIDUAL @map("individual")
  VIP        @map("vip")
}

enum ExcursionOfferType {
  EXCURSION @map("excursion")
  TOUR      @map("tour")
}

enum ExcursionPriceType {
  PER_PERSON @map("per_person")
  PER_GROUP  @map("per_group")
}

enum RoomPriceType {
  PER_ROOM   @map("per_room")
  PER_PERSON @map("per_person")
}

enum ExcursionDifficulty {
  EASY   @map("easy")
  MEDIUM @map("medium")
  HARD   @map("hard")
}

enum ExcursionScheduleMode {
  TEXT     @map("text")
  RULES    @map("rules")
  SESSIONS @map("sessions")
}

enum ExcursionAvailabilityMode {
  REGULAR    @map("regular")
  DATED      @map("dated")
  ON_REQUEST @map("on_request")
}

enum ExcursionSessionStatus {
  AVAILABLE @map("available")
  SOLD_OUT  @map("sold_out")
  CANCELED  @map("canceled")
}

enum PetsPolicy {
  FORBIDDEN  @map("forbidden")
  ON_REQUEST @map("on_request")
  ALLOWED    @map("allowed")
}

enum SmokingPolicy {
  FORBIDDEN  @map("forbidden")
  ON_REQUEST @map("on_request")
  ALLOWED    @map("allowed")
}

enum MediaType {
  IMAGE @map("image")
  VIDEO @map("video")
}

enum BathroomType {
  IN_ROOM  @map("in_room")
  ON_FLOOR @map("on_floor")
  OUTSIDE  @map("outside")
}

enum ApplicationStatus {
  NEW         @map("new")
  IN_PROGRESS @map("in_progress")
  CLOSED      @map("closed")
}

enum PaymentStatus {
  CREATED   @map("created")
  PENDING   @map("pending")
  SUCCEEDED @map("succeeded")
  CANCELED  @map("canceled")
}

enum PaymentProvider {
  MOCK     @map("mock")
  YOOKASSA @map("yookassa")
  MANAGER  @map("manager")
}

enum ObjectPaymentStatus {
  PAID    @map("paid")
  UNPAID  @map("unpaid")
  DEMO    @map("demo")
  EXPIRED @map("expired")
}

enum ObjectTariffType {
  SEASON    @map("season")
  OFFSEASON @map("offseason")
  YEARLY    @map("yearly")
  DEMO      @map("demo")
}

enum OccupancyStatus {
  CONFIRMED  @map("confirmed")
  CHECKED_IN @map("checked_in")
}

enum ReviewStatus {
  PENDING @map("pending")
  ACTIVE  @map("active")
  DELETED @map("deleted")
}

enum ReviewReactionValue {
  LIKE    @map("like")
  DISLIKE @map("dislike")
}

enum ReviewReportStatus {
  PENDING   @map("pending")
  DISMISSED @map("dismissed")
  RESOLVED  @map("resolved")
}

enum ApplicationEntityType {
  PROPERTY  @map("property")
  EXCURSION @map("excursion")
}

enum ReviewEntityType {
  PROPERTY  @map("property")
  EXCURSION @map("excursion")
  TRANSFER  @map("transfer")
}

enum AdminMessageSourceType {
  OBJECT    @map("object")
  EXCURSION @map("excursion")
}

enum CustomLocationStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")
}

model User {
  id                        String                 @id @default(cuid())
  phone                     String                 @unique
  firstName                 String
  lastName                  String
  passwordHash              String
  email                     String?
  pendingEmail              String?
  avatarUrl                 String?
  avatarStorageKey          String?
  emailChangeTokenHash      String?
  emailChangeTokenExpiresAt DateTime?
  emailChangeRequestedAt    DateTime?
  emailVerifiedAt           DateTime?
  passwordChangedAt         DateTime?
  sessionVersion            Int                    @default(0)
  lastLoginAt               DateTime?
  lastSeenAt                DateTime?
  lastLogoutAt              DateTime?
  role                      UserRole               @default(USER)
  deletedAt                 DateTime?
  deletionExpiresAt         DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  properties                Property[]
  excursions                Excursion[]
  transfers                 Transfer[]
  applications              Application[]          @relation("GuestApplications")
  payments                  Payment[]              @relation("OwnerPayments")
  confirmedPayments         Payment[]              @relation("ConfirmedPayments")
  favoriteProperties        FavoriteProperty[]
  adminMessages             AdminMessage[]         @relation("AdminMessageSender")
  reviews                   Review[]
  reviewReactions           ReviewReaction[]
  reviewReports             ReviewReport[]         @relation("ReviewReporter")
  passwordResetRequests     PasswordResetRequest[] @relation("PasswordResetRequestedByUser")
  passwordResetTokens       PasswordResetToken[]
  chatConsentGiven          Boolean                @default(false) @map("chat_consent_given")
  supportChat               SupportChat?

  @@index([deletedAt, deletionExpiresAt, createdAt])
  @@index([lastSeenAt])
  @@index([lastLoginAt])
  @@index([pendingEmail])
}

model PasswordResetRequest {
  id            String                     @id @default(cuid())
  phone         String
  userId        String
  status        PasswordResetRequestStatus @default(PENDING)
  processedAt   DateTime?
  processedById String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  user          User                       @relation("PasswordResetRequestedByUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, status, createdAt])
  @@index([processedById, createdAt])
  @@index([phone, createdAt])
}

model PasswordResetToken {
  id              String    @id @default(cuid())
  userId          String
  tokenHash       String    @unique
  issuedByAdminId String?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, usedAt])
}

model AdminSessionState {
  login          String   @id
  sessionVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WebhookReceipt {
  id                String   @id @default(cuid())
  provider          String
  fingerprint       String
  providerEventId   String?
  providerPaymentId String?
  localPaymentId    String?
  outcome           String
  metadata          Json?
  receivedAt        DateTime @default(now())
  processedAt       DateTime @default(now())

  @@unique([provider, fingerprint])
  @@index([provider, providerPaymentId, processedAt])
  @@index([localPaymentId, processedAt])
}

model Property {
  id                            String                     @id @default(cuid())
  ownerId                       String
  type                          String?
  locationId                    String?
  locationName                  String?
  name                          String?
  address                       String?
  seaDistance                   String?
  latitude                      Decimal?                   @db.Decimal(9, 6)
  longitude                     Decimal?                   @db.Decimal(9, 6)
  phone                         String?
  phoneName                     String?
  phone2                        String?
  phone2Name                    String?
  phone3                        String?
  phone3Name                    String?
  websiteUrl                    String?
  contactEmail                  String?
  contactPersonName             String?
  contactPersonRole             String?
  listingChannels               String?
  whatsappUrl                   String?
  telegramUrl                   String?
  vkUrl                         String?
  maxUrl                        String?
  okUrl                         String?
  receiveRequests               Boolean                    @default(true)
  showEmail                     Boolean                    @default(false)
  description                   String?
  faqItems                      Json                       @default("[]")
  checkInFrom                   String?
  checkOutUntil                 String?
  childrenAllowed               Boolean?
  childrenMinAge                Int?
  petsPolicy                    PetsPolicy?
  smokingPolicy                 SmokingPolicy?
  quietHoursEnabled             Boolean?
  quietHoursFrom                String?
  quietHoursTo                  String?
  parkingInfo                   String?
  mealOptions                   String?
  prepaymentPolicy              String?
  classificationApplicable      Boolean                    @default(false)
  starRating                    Int?
  registryNumber                String?
  registryNumberPending         String?
  registryModerationSubmittedAt DateTime?
  registryDetails               String?
  selfAssessmentPassed          Boolean?
  moderationNotes               String?
  moderatedById                 String?
  moderatedAt                   DateTime?
  pendingEditStatus             PropertyStatus?
  publishedSnapshot             Json?
  avgRating                     Decimal                    @default(0) @db.Decimal(3, 2)
  reviewsCount                  Int                        @default(0)
  searchImpressions             Int                        @default(0)
  profileViews                  Int                        @default(0)
  favoritesCount                Int                        @default(0)
  status                        PropertyStatus             @default(DRAFT)
  isPublishedVisible            Boolean                    @default(true)
  paymentStatus                 ObjectPaymentStatus        @default(UNPAID)
  tariffType                    ObjectTariffType?
  paidFrom                      DateTime?
  paidUntil                     DateTime?
  paidAmount                    Decimal?                   @db.Decimal(10, 2)
  paidAt                        DateTime?
  ownerDeletedAt                DateTime?
  ownerDeletionExpiresAt        DateTime?
  createdAt                     DateTime                   @default(now())
  updatedAt                     DateTime                   @updatedAt
  owner                         User                       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // Catalog amenities selected by checkbox.
  amenities                     PropertyAmenity[]
  // Free-text amenities entered by owner manually.
  customAmenities               PropertyCustomAmenity[]
  roomAmenitySettings           ObjectRoomAmenitySetting[]
  documents                     PropertyDocument[]
  media                         Media[]
  rooms                         Room[]
  applications                  Application[]
  adminMessages                 AdminMessage[]
  payments                      Payment[]
  favoritedBy                   FavoriteProperty[]
  reviews                       Review[]
  sourceCustomLocations         CustomLocation[]           @relation("CustomLocationSourceProperty")

  @@index([ownerId, updatedAt])
  @@index([status, updatedAt])
  @@index([isPublishedVisible, status, updatedAt])
  @@index([paymentStatus, paidUntil])
  @@index([tariffType, paidUntil])
  @@index([pendingEditStatus, updatedAt])
  @@index([ownerDeletedAt, ownerDeletionExpiresAt])
}

model FavoriteProperty {
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@index([propertyId, createdAt])
  @@index([userId, createdAt])
}

model CustomLocation {
  id               String               @id @default(cuid())
  slug             String               @unique
  name             String
  normalizedName   String               @unique
  status           CustomLocationStatus @default(PENDING)
  sourcePropertyId String?
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  sourceProperty   Property?            @relation("CustomLocationSourceProperty", fields: [sourcePropertyId], references: [id], onDelete: SetNull)

  @@index([status, name])
}

model ExcursionDistrict {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  locations   ExcursionLocation[]
  excursions  Excursion[]
  attractions Attraction[]
  transfers   Transfer[]

  @@index([isActive, name])
}

model ExcursionCategory {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String?
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  excursions  Excursion[]

  @@index([isActive, sortOrder, name])
}

model ExcursionLocation {
  id                String                    @id @default(cuid())
  slug              String                    @unique
  name              String
  normalizedName    String                    @unique
  kind              ExcursionLocationKind     @default(OTHER)
  districtId        String?
  latitude          Decimal?                  @db.Decimal(9, 6)
  longitude         Decimal?                  @db.Decimal(9, 6)
  aliases           String[]                  @default([])
  isMajor           Boolean                   @default(false)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  district          ExcursionDistrict?        @relation(fields: [districtId], references: [id], onDelete: SetNull)
  mainExcursions    Excursion[]               @relation("ExcursionMainLocation")
  anchorExcursions  Excursion[]               @relation("ExcursionAnchorLocation")
  meetingExcursions Excursion[]               @relation("ExcursionMeetingLocation")
  pickupExcursions  ExcursionPickupLocation[]
  routeExcursions   ExcursionRouteLocation[]
  attractions       Attraction[]
  transfers         Transfer[]

  @@index([districtId, isMajor])
  @@index([name])
}

model ExcursionPickupLocation {
  excursionId String
  locationId  String
  createdAt   DateTime          @default(now())
  excursion   Excursion         @relation(fields: [excursionId], references: [id], onDelete: Cascade)
  location    ExcursionLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([excursionId, locationId])
  @@index([locationId])
}

model ExcursionRouteLocation {
  excursionId String
  locationId  String
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  excursion   Excursion         @relation(fields: [excursionId], references: [id], onDelete: Cascade)
  location    ExcursionLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([excursionId, locationId, sortOrder])
  @@index([excursionId, sortOrder])
  @@index([locationId])
}

model ExcursionSession {
  id                     String                 @id @default(cuid())
  excursionId            String
  startAt                DateTime
  endAt                  DateTime?
  capacity               Int?
  priceOverride          Decimal?               @db.Decimal(10, 2)
  status                 ExcursionSessionStatus @default(AVAILABLE)
  bookingDeadlineMinutes Int?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  excursion              Excursion              @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@index([excursionId, startAt])
  @@index([status, startAt])
}

model ExcursionScheduleRule {
  id              String    @id @default(cuid())
  excursionId     String
  dateFrom        DateTime? @db.Date
  dateTo          DateTime? @db.Date
  weekdays        Int[]     @default([])
  timeStarts      String[]  @default([])
  durationMinutes Int?
  capacityDefault Int?
  priceOverride   Decimal?  @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  excursion       Excursion @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@index([excursionId, dateFrom, dateTo])
}

model ExcursionScheduleException {
  id                 String    @id @default(cuid())
  excursionId        String
  date               DateTime  @db.Date
  isClosed           Boolean   @default(false)
  overrideTimeStarts String[]  @default([])
  overrideCapacity   Int?
  overridePrice      Decimal?  @db.Decimal(10, 2)
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  excursion          Excursion @relation(fields: [excursionId], references: [id], onDelete: Cascade)

  @@unique([excursionId, date])
  @@index([date])
}

model Excursion {
  id                        String                       @id @default(cuid())
  ownerId                   String
  offerType                 ExcursionOfferType           @default(EXCURSION)
  subtypeLabel              String?
  title                     String?
  locationId                String?
  locationName              String?
  mainLocationId            String?
  anchorLocationId          String?
  districtId                String?
  categoryId                String?
  address                   String?
  latitude                  Decimal?                     @db.Decimal(9, 6)
  longitude                 Decimal?                     @db.Decimal(9, 6)
  startPoint                String?
  meetingPointText          String?
  meetingLocationId         String?
  description               String?
  shortDescription          String?
  fullDescription           String?
  routeDescription          String?
  highlights                Json                         @default("[]")
  durationMinutes           Int?
  durationDays              Int?
  durationNights            Int?
  itineraryDays             Json                         @default("[]")
  finishPoint               String?
  scheduleText              String?
  scheduleMode              ExcursionScheduleMode        @default(TEXT)
  availabilityMode          ExcursionAvailabilityMode    @default(REGULAR)
  availabilityNote          String?
  format                    ExcursionFormat?
  groupSizeMin              Int?
  groupSizeMax              Int?
  languageCodes             String[]                     @default([])
  ageLimit                  Int?
  isKidFriendly             Boolean?
  difficulty                ExcursionDifficulty?
  priceType                 ExcursionPriceType           @default(PER_PERSON)
  priceFrom                 Decimal?                     @db.Decimal(10, 2)
  priceTo                   Decimal?                     @db.Decimal(10, 2)
  currency                  String                       @default("RUB") @db.VarChar(3)
  includedText              String?
  notIncludedText           String?
  cancellationPolicy        String?
  physicalRequirements      String[]                     @default([])
  whatToBring               String[]                     @default([])
  meetingPointLat           Decimal?                     @db.Decimal(9, 6)
  meetingPointLng           Decimal?                     @db.Decimal(9, 6)
  minBookingNoticeHours     Int?
  hasGuideLicense           Boolean                      @default(false)
  pickupAvailable           Boolean                      @default(false)
  receiveRequests           Boolean                      @default(true)
  tags                      String[]                     @default([])
  instantConfirmation       Boolean                      @default(false)
  contactFirstName          String?
  contactLastName           String?
  contactPhone              String?
  contactPhone2             String?
  contactEmail              String?
  websiteUrl                String?
  whatsappUrl               String?
  telegramUrl               String?
  vkUrl                     String?
  maxUrl                    String?
  okUrl                     String?
  photoUrls                 String[]                     @default([])
  sectionPhotoGroups        Json                         @default("{}")
  videoUrls                 String[]                     @default([])
  timeline                  Json                         @default("[]")
  pricingTiers              Json                         @default("[]")
  faqItems                  Json                         @default("[]")
  extraOptions              Json                         @default("[]")
  includedItems             String[]                     @default([])
  excludedItems             String[]                     @default([])
  transferDetails           String?
  cancellationPolicyType    String?
  priceUnitLabel            String?
  // ── Tour logistics ──
  tourKind                  String? // ONE_DAY | WEEKEND | MULTI_DAY | JEEP | BOAT | HIKING | BUS | COMBINED | EXPEDITION | CRUISE | OTHER
  transportModes            String[]                     @default([]) // WALKING | BUS | MINIVAN | CAR | JEEP | ATV | BOAT | TRAIN | FLIGHT | MIXED
  departureMode             String? // FIXED_DATES | ON_REQUEST | DAILY | SEASONAL | PRIVATE_ONLY
  arrivalInfo               String?
  departureInfo             String?
  // ── Accommodation ──
  accommodationProvided     Boolean?
  accommodationType         String? // HOTEL | GUESTHOUSE | HOSTEL | CAMPING | APARTMENT | VILLA | MIXED
  accommodationNights       Int?
  accommodationFormat       String?
  accommodationStars        String? // e.g. "3*", "4*", "без звёзд"
  roomTypes                 String[]                     @default([]) // SINGLE | DOUBLE | TWIN | TRIPLE | SHARED | CAMPING
  singleSupplementAvailable Boolean?
  singleSupplementPrice     Decimal?                     @db.Decimal(10, 2)
  accommodationComment      String?
  // ── Meals ──
  mealPlan                  String? // NONE | BREAKFAST | HALF_BOARD | FULL_BOARD | ALL_INCLUSIVE | CUSTOM
  mealDetails               String?
  // ── Safety & documents ──
  documentsRequired         String[]                     @default([])
  insuranceIncluded         Boolean?
  insuranceComment          String?
  equipmentProvided         String[]                     @default([])
  safetyInfo                String?
  routeConditions           String?
  avgRating                 Decimal                      @default(0) @db.Decimal(3, 2)
  reviewsCount              Int                          @default(0)
  profileViews              Int                          @default(0)
  moderationNotes           String?
  moderatedById             String?
  moderatedAt               DateTime?
  pendingEditStatus         ExcursionStatus?
  publishedSnapshot         Json?
  status                    ExcursionStatus              @default(DRAFT)
  isPublishedVisible        Boolean                      @default(true)
  deletedAt                 DateTime?
  deletionExpiresAt         DateTime?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  owner                     User                         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  mainLocation              ExcursionLocation?           @relation("ExcursionMainLocation", fields: [mainLocationId], references: [id], onDelete: SetNull)
  anchorLocation            ExcursionLocation?           @relation("ExcursionAnchorLocation", fields: [anchorLocationId], references: [id], onDelete: SetNull)
  meetingLocation           ExcursionLocation?           @relation("ExcursionMeetingLocation", fields: [meetingLocationId], references: [id], onDelete: SetNull)
  district                  ExcursionDistrict?           @relation(fields: [districtId], references: [id], onDelete: SetNull)
  category                  ExcursionCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pickupLocations           ExcursionPickupLocation[]
  routeLocations            ExcursionRouteLocation[]
  sessions                  ExcursionSession[]
  scheduleRules             ExcursionScheduleRule[]
  scheduleExceptions        ExcursionScheduleException[]
  applications              Application[]
  adminMessages             AdminMessage[]
  reviews                   Review[]
  payments                  Payment[]

  @@index([ownerId, updatedAt])
  @@index([status, updatedAt])
  @@index([isPublishedVisible, status, updatedAt])
  @@index([pendingEditStatus, updatedAt])
  @@index([deletedAt, deletionExpiresAt])
  @@index([anchorLocationId, status, updatedAt])
  @@index([mainLocationId, status, updatedAt])
  @@index([districtId, status, updatedAt])
  @@index([categoryId, status, updatedAt])
  @@index([meetingLocationId])
  @@index([scheduleMode])
  @@index([pickupAvailable])
}

model Attraction {
  id                 String             @id @default(cuid())
  title              String
  slug               String             @unique
  category           String?
  locationId         String?
  locationName       String?
  districtId         String?
  address            String?
  latitude           Decimal?           @db.Decimal(9, 6)
  longitude          Decimal?           @db.Decimal(9, 6)
  shortDescription   String?
  description        String?
  photoUrls          String[]           @default([])
  websiteUrl         String?
  status             AttractionStatus   @default(DRAFT)
  isPublishedVisible Boolean            @default(true)
  publishedAt        DateTime?
  createdByLogin     String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  location           ExcursionLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  district           ExcursionDistrict? @relation(fields: [districtId], references: [id], onDelete: SetNull)

  @@index([status, isPublishedVisible, updatedAt])
  @@index([locationId, status, updatedAt])
  @@index([districtId, status, updatedAt])
}

model Transfer {
  id                 String             @id @default(cuid())
  ownerId            String
  title              String?
  slug               String             @unique
  transferType       String?
  vehicleClass       String?
  vehicleModel       String?
  seats              Int?
  luggage            Int?
  locationId         String?
  locationName       String?
  districtId         String?
  serviceArea        String?
  routeExamples      String?
  latitude           Decimal?           @db.Decimal(9, 6)
  longitude          Decimal?           @db.Decimal(9, 6)
  priceFrom          Decimal?           @db.Decimal(10, 2)
  priceUnitLabel     String?
  currency           String             @default("RUB") @db.VarChar(3)
  shortDescription   String?
  description        String?
  photoUrls          String[]           @default([])
  serviceTags        String[]           @default([])
  fleet              Json               @default("[]")
  contactName        String?
  phone              String?
  phone2             String?
  websiteUrl         String?
  whatsappUrl        String?
  telegramUrl        String?
  vkUrl              String?
  maxUrl             String?
  okUrl              String?
  receiveRequests    Boolean            @default(true)
  avgRating          Decimal            @default(0) @db.Decimal(3, 2)
  reviewsCount       Int                @default(0)
  profileViews       Int                @default(0)
  moderationNotes    String?
  status             TransferStatus     @default(DRAFT)
  pendingEditStatus  TransferStatus?
  publishedSnapshot  Json?
  isPublishedVisible Boolean            @default(true)
  publishedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  owner              User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  location           ExcursionLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  district           ExcursionDistrict? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  reviews            Review[]
  payments           Payment[]

  @@index([ownerId, updatedAt])
  @@index([status, isPublishedVisible, updatedAt])
  @@index([pendingEditStatus, updatedAt])
  @@index([locationId, status, updatedAt])
  @@index([districtId, status, updatedAt])
}

model Review {
  id             String           @id @default(cuid())
  entityType     ReviewEntityType @default(PROPERTY)
  propertyId     String?
  excursionId    String?
  transferId     String?
  userId         String
  rating         Decimal          @db.Decimal(2, 1)
  text           String
  likesCount     Int              @default(0)
  dislikesCount  Int              @default(0)
  status         ReviewStatus     @default(PENDING)
  ownerReply     String?
  ownerRepliedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  property       Property?        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  excursion      Excursion?       @relation(fields: [excursionId], references: [id], onDelete: Cascade)
  transfer       Transfer?        @relation(fields: [transferId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions      ReviewReaction[]
  reports        ReviewReport[]

  @@unique([userId, propertyId])
  @@unique([userId, excursionId])
  @@unique([userId, transferId])
  @@index([entityType, createdAt])
  @@index([propertyId, status, createdAt])
  @@index([excursionId, status, createdAt])
  @@index([transferId, status, createdAt])
  @@index([userId, entityType, createdAt])
}

model ReviewReaction {
  reviewId  String
  userId    String
  value     ReviewReactionValue
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  review    Review              @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reviewId, userId])
  @@index([userId, createdAt])
  @@index([reviewId, value])
}

model ReviewReport {
  id         String             @id @default(cuid())
  reviewId   String
  reporterId String
  reason     String
  comment    String?
  status     ReviewReportStatus @default(PENDING)
  createdAt  DateTime           @default(now())
  review     Review             @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter   User               @relation("ReviewReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reviewId, reporterId])
  @@index([status, createdAt])
  @@index([reviewId, createdAt])
  @@index([reporterId, createdAt])
}

model AdminActionLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetType  String
  targetId    String
  details     Json?
  createdAt   DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetType, targetId, createdAt])
}

model AdminMessage {
  id           String                 @id @default(cuid())
  senderUserId String
  sourceType   AdminMessageSourceType
  propertyId   String?
  excursionId  String?
  message      String
  createdAt    DateTime               @default(now())
  senderUser   User                   @relation("AdminMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  property     Property?              @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  excursion    Excursion?             @relation(fields: [excursionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([sourceType, createdAt])
  @@index([senderUserId, createdAt])
  @@index([propertyId, createdAt])
  @@index([excursionId, createdAt])
}

model Amenity {
  id         String            @id
  name       String
  category   String
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  // Back-reference to properties that selected this amenity.
  properties PropertyAmenity[]

  @@index([category, name])
}

model PropertyAmenity {
  propertyId String
  amenityId  String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@index([amenityId])
}

model PropertyCustomAmenity {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, name])
}

model Room {
  id             String              @id @default(cuid())
  propertyId     String
  title          String
  beds           Int
  extraBeds      Int                 @default(0)
  roomsCount     Int
  areaSqm        Decimal?            @db.Decimal(8, 2)
  bathroomType   BathroomType
  meta           Json?
  sortOrder      Int                 @default(0)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  property       Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  features       RoomFeatureOnRoom[]
  customFeatures RoomCustomFeature[]
  media          Media[]
  prices         RoomPrice[]
  occupancies    RoomOccupancy[]
  applications   Application[]

  @@index([propertyId, isActive, sortOrder])
  @@index([propertyId, isActive, updatedAt])
}

model Application {
  id           String                @id @default(cuid())
  entityType   ApplicationEntityType @default(PROPERTY)
  propertyId   String?
  excursionId  String?
  roomId       String?
  guestUserId  String
  dateFrom     DateTime              @db.Date
  dateTo       DateTime              @db.Date
  guestsCount  Int
  message      String?
  contactName  String
  contactPhone String
  contactEmail String
  status       ApplicationStatus     @default(NEW)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  property     Property?             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  excursion    Excursion?            @relation(fields: [excursionId], references: [id], onDelete: Cascade)
  room         Room?                 @relation(fields: [roomId], references: [id], onDelete: SetNull)
  guestUser    User                  @relation("GuestApplications", fields: [guestUserId], references: [id], onDelete: Cascade)

  @@index([entityType, status, createdAt])
  @@index([propertyId, status, createdAt])
  @@index([excursionId, status, createdAt])
  @@index([guestUserId, createdAt])
  @@index([roomId])
}

model Payment {
  id                  String          @id @default(cuid())
  propertyId          String?
  excursionId         String?
  transferId          String?
  ownerId             String
  amount              Decimal         @db.Decimal(10, 2)
  tariffCode          String
  tariffType          ObjectTariffType?
  roomCount           Int
  status              PaymentStatus   @default(CREATED)
  provider            PaymentProvider @default(MOCK)
  providerPaymentId   String?
  idempotenceKey      String          @unique
  confirmationUrl     String?
  providerPayload     Json?
  paidFrom            DateTime?
  placementValidUntil DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  paidAt              DateTime?
  canceledAt          DateTime?
  managerNotes        String?
  confirmedById       String?
  confirmedBy         User?           @relation("ConfirmedPayments", fields: [confirmedById], references: [id], onDelete: SetNull)
  property            Property?       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  excursion           Excursion?      @relation(fields: [excursionId], references: [id], onDelete: Cascade)
  transfer            Transfer?       @relation(fields: [transferId], references: [id], onDelete: Cascade)
  owner               User            @relation("OwnerPayments", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([propertyId, status, createdAt])
  @@index([propertyId, status, placementValidUntil])
  @@index([propertyId, tariffType, placementValidUntil])
  @@index([excursionId, status, createdAt])
  @@index([transferId, status, createdAt])
  @@index([ownerId, createdAt])
  @@index([providerPaymentId])
  @@index([provider, status])
}

model RoomPrice {
  id        String        @id @default(cuid())
  roomId    String
  dateFrom  DateTime      @db.Date
  dateTo    DateTime      @db.Date
  price     Decimal       @db.Decimal(10, 2)
  priceType RoomPriceType @default(PER_ROOM)
  minGuests Int?
  currency  String        @default("RUB") @db.VarChar(3)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  room      Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, dateFrom, dateTo])
  @@index([roomId, createdAt])
}

model RoomOccupancy {
  id            String          @id @default(cuid())
  roomId        String
  dateFrom      DateTime        @db.Date
  dateTo        DateTime        @db.Date
  timeFrom      String?
  timeTo        String?
  status        OccupancyStatus @default(CONFIRMED)
  tag           String?         @db.VarChar(80)
  source        String?         @db.VarChar(80)
  color         String?         @db.VarChar(16)
  adultsCount   Int             @default(1)
  childrenCount Int             @default(0)
  guestName     String?
  guestPhone    String?
  guestContacts String?
  description   String?         @db.VarChar(250)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  room          Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, dateFrom, dateTo])
  @@index([roomId, createdAt])
}

model RoomFeature {
  id             String                     @id
  name           String
  category       String
  isActive       Boolean                    @default(true)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  rooms          RoomFeatureOnRoom[]
  objectSettings ObjectRoomAmenitySetting[]

  @@index([category, name])
}

model RoomFeatureOnRoom {
  roomId    String
  featureId String
  createdAt DateTime    @default(now())
  room      Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  feature   RoomFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([roomId, featureId])
  @@index([featureId])
}

model RoomCustomFeature {
  id        String   @id @default(cuid())
  roomId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, name])
}

model ObjectRoomAmenitySetting {
  id                   String      @id @default(cuid())
  propertyId           String
  featureId            String
  enabled              Boolean     @default(false)
  isPaid               Boolean?
  isKeyAmenity         Boolean     @default(false)
  applyToAllCategories Boolean     @default(true)
  categoryIds          String[]    @default([])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  property             Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  feature              RoomFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([propertyId, featureId])
  @@index([propertyId, updatedAt])
  @@index([propertyId, isKeyAmenity])
  @@index([featureId])
}

model PropertyDocument {
  id         String   @id @default(cuid())
  propertyId String
  type       String
  title      String
  fileName   String
  mimeType   String
  fileSize   Int
  url        String
  storageKey String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, createdAt])
}

model ViewLog {
  id         String   @id @default(cuid())
  entityType String   @db.VarChar(20)
  entityId   String
  date       DateTime @db.Date
  count      Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId, date])
  @@index([entityType, entityId, date])
}

model Media {
  id           String    @id @default(cuid())
  propertyId   String?
  roomId       String?
  type         MediaType
  url          String
  storageKey   String
  mimeType     String
  fileSize     Int
  originalName String?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room         Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([propertyId, sortOrder])
  @@index([roomId, sortOrder])
  @@index([type, createdAt])
}

// ─── Support Chat ───────────────────────────────────────────────

model SupportChat {
  id        String           @id @default(cuid())
  userId    String           @unique @map("user_id")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  SupportMessage[]

  @@index([updatedAt])
  @@map("support_chats")
}

model SupportMessage {
  id         String      @id @default(cuid())
  chatId     String      @map("chat_id")
  senderType String      @map("sender_type") @db.VarChar(20)
  senderName String?     @map("sender_name") @db.VarChar(100)
  text       String
  imageUrl   String?     @map("image_url") @db.VarChar(500)
  createdAt  DateTime    @default(now()) @map("created_at")
  chat       SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@map("support_messages")
}

model ChatManager {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(100)
  photoUrl  String?  @map("photo_url") @db.VarChar(500)
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("chat_managers")
}

model SiteSetting {
  key       String   @id @db.VarChar(100)
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
