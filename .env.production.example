NODE_ENV="production"
POSTGRES_DB="krymvokrug"
POSTGRES_USER="krymvokrug"
POSTGRES_PASSWORD="change-me-to-a-long-random-password"
DATABASE_URL="postgresql://krymvokrug:change-me-to-a-long-random-password@db:5432/krymvokrug?schema=public"
PRISMA_LOG_QUERIES="false"
JWT_SECRET="change-me-to-a-32-plus-char-random-secret"
ADMIN_LOGIN="admin"
# Generate with: node scripts/hash-admin-password.mjs "YourStrongAdminPassword"
ADMIN_PASSWORD_HASH="\$2b\$10\$replace-with-your-bcrypt-hash"
ADMIN_JWT_SECRET="change-me-to-another-32-plus-char-random-secret"
NEXT_PUBLIC_APP_URL="https://krymvokrug.ru"
CSRF_TRUSTED_ORIGINS="https://krymvokrug.ru https://www.krymvokrug.ru"
RATE_LIMIT_MODE="memory"
SECURITY_EMAIL_DELIVERY_MODE="log"
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""
YANDEX_GEOCODER_API_KEY=""
S3_ENDPOINT=""
S3_REGION="ru-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL=""
CRON_SECRET="change-me-to-a-random-hex-string"
LISTING_ANALYTICS_TIME_ZONE="Europe/Moscow"
LISTING_ANALYTICS_AUTO_UPDATE_HOUR="4"
LISTING_ANALYTICS_CRON_BATCH_LIMIT="150"
ACME_EMAIL="admin@krymvokrug.ru"
