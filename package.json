{
  "name": "boking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:cache": "node scripts/clean-cache.js",
    "clean:cache:all": "node scripts/clean-cache.js --next",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "predev": "npm run clean:cache",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "postdev": "npm run clean:cache",
    "prebuild": "npm run clean:cache && npm run check:mojibake",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "pretest": "npm run clean:cache",
    "test": "vitest run",
    "posttest": "npm run clean:cache",
    "test:watch": "vitest",
    "pretest:coverage": "npm run clean:cache",
    "test:coverage": "vitest run --coverage",
    "posttest:coverage": "npm run clean:cache",
    "pretest:e2e": "npm run clean:cache",
    "test:e2e": "playwright test",
    "posttest:e2e": "npm run clean:cache",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "format:write": "prettier --write .",
    "db:migrate": "prisma migrate dev",
    "db:seed-districts": "npx tsx scripts/seed-districts.ts",
    "db:cleanup-drafts": "node scripts/cleanup-drafts.mjs",
    "db:cleanup-drafts:dry": "node scripts/cleanup-drafts.mjs --dry-run",
    "format": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.16.2",
    "@tabler/icons-react": "^3.41.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.15",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "prisma": "^6.16.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.0",
    "vitest": "^4.0.18"
  }
}
